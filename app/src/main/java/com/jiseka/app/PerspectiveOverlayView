package com.jiseka.app

import android.content.Context
import android.graphics.Bitmap
import android.graphics.Canvas
import android.graphics.Matrix
import android.graphics.Paint
import android.graphics.PointF
import android.util.AttributeSet
import android.view.View
import kotlin.math.max

class PerspectiveOverlayView @JvmOverloads constructor(
    context: Context, attrs: AttributeSet? = null, defStyleAttr: Int = 0
) : View(context, attrs, defStyleAttr) {

    private val perspectiveMatrix = Matrix()
    private val paint = Paint(Paint.ANTI_ALIAS_FLAG).apply {
        isFilterBitmap = true // 텍스처 찌그러짐 시 픽셀 깨짐(Aliasing) 방지
    }
    
    private var blurTexture: Bitmap? = null
    private var dstPoints: FloatArray? = null 
    private var srcPoints: FloatArray? = null 

    /**
     * 외부(Activity/Fragment)에서 번호판 꼭지점 좌표를 주입할 때 호출
     * @param imageW OpenCV가 분석한 원본 비트맵 가로
     * @param imageH OpenCV가 분석한 원본 비트맵 세로
     * @param cvPoints OpenCV에서 찾은 4개의 꼭지점 (시계방향: TL, TR, BR, BL)
     * @param texture 덮어씌울 모자이크/블러 비트맵 리소스
     */
    fun setOverlayData(imageW: Float, imageH: Float, cvPoints: List<PointF>?, texture: Bitmap?) {
        if (cvPoints == null || texture == null) {
            blurTexture = null
            invalidate()
            return
        }

        this.blurTexture = texture
        
        // 1. 블러 텍스처 원본 4개 꼭지점
        val tw = texture.width.toFloat()
        val th = texture.height.toFloat()
        this.srcPoints = floatArrayOf(
            0f, 0f, tw, 0f, tw, th, 0f, th
        )
        
        // 2. 화면 CenterCrop 좌표계 변환 매핑
        this.dstPoints = mapToViewCoordinates(imageW, imageH, width.toFloat(), height.toFloat(), cvPoints)
        
        invalidate()
    }

    /**
     * 카메라 이미지 좌표계를 View(CenterCrop) 좌표계로 동기화
     */
    private fun mapToViewCoordinates(
        imageW: Float, imageH: Float, viewW: Float, viewH: Float, cvPoints: List<PointF>
    ): FloatArray {
        val scale = max(viewW / imageW, viewH / imageH)
        val offsetX = (viewW - (imageW * scale)) / 2f
        val offsetY = (viewH - (imageH * scale)) / 2f

        val mappedPoints = FloatArray(8)
        for (i in 0 until 4) {
            mappedPoints[i * 2] = (cvPoints[i].x * scale) + offsetX
            mappedPoints[i * 2 + 1] = (cvPoints[i].y * scale) + offsetY
        }
        return mappedPoints
    }

    override fun onDraw(canvas: Canvas) {
        super.onDraw(canvas)
        
        val texture = blurTexture
        val src = srcPoints
        val dst = dstPoints

        if (texture != null && src != null && dst != null) {
            // CPU 연산을 생략하고 GPU 하드웨어 가속을 통해 원근 변환(Perspective Transform) 렌더링
            perspectiveMatrix.setPolyToPoly(src, 0, dst, 0, 4)
            canvas.drawBitmap(texture, perspectiveMatrix, paint)
        }
    }
}
